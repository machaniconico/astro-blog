---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero Section -->
			<section class="hero">
				<div class="hero-content">
					<p class="hero-eyebrow">Personal Dev Journal</p>
					<h1 class="hero-title">個人開発の<span class="hero-title-accent">すゝめ</span></h1>
					<p class="hero-description">
						コードを書き、思考を記録し、日々を綴る。<br />
						アイデアを形にする過程を、ここに残していく。
					</p>
					<div class="hero-cta">
						<a href="/works" class="btn btn-primary">制作物を見る</a>
						<a href="/blog" class="btn btn-secondary">記事を読む</a>
						<a href="/diary" class="btn btn-secondary">日記を見る</a>
					</div>
				</div>
				<div class="hero-decoration" aria-hidden="true">
					<div class="decoration-ring ring-1"></div>
					<div class="decoration-ring ring-2"></div>
					<div class="decoration-ring ring-3"></div>
					<div class="decoration-dots"></div>
				</div>
			</section>

			<!-- Navigation Cards -->
			<section class="nav-section">
				<h2 class="section-label">コンテンツ</h2>
				<div class="cards-grid">

					<!-- Works Card -->
					<a href="/works" class="nav-card">
						<div class="card-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<rect width="20" height="14" x="2" y="3" rx="2"/>
								<line x1="8" x2="16" y1="21" y2="21"/>
								<line x1="12" x2="12" y1="17" y2="21"/>
							</svg>
						</div>
						<div class="card-body">
							<h3 class="card-title">成果物置き場</h3>
							<p class="card-description">
								これまで作ったWebアプリ・ツールを一覧で紹介。使った技術スタックや開発背景も合わせて記録。
							</p>
							<div class="card-tags">
								<span class="tag">Web App</span>
								<span class="tag">CLI Tool</span>
								<span class="tag">OSS</span>
							</div>
						</div>
						<div class="card-arrow">
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
							</svg>
						</div>
					</a>

					<!-- Blog Card -->
					<a href="/blog" class="nav-card">
						<div class="card-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/>
								<polyline points="14 2 14 8 20 8"/>
								<line x1="16" x2="8" y1="13" y2="13"/>
								<line x1="16" x2="8" y1="17" y2="17"/>
								<line x1="10" x2="8" y1="9" y2="9"/>
							</svg>
						</div>
						<div class="card-body">
							<h3 class="card-title">開発記録の日記</h3>
							<p class="card-description">
								技術メモ、学習記録、開発日誌。試行錯誤の軌跡をMarkdownで残していく場所。
							</p>
							<div class="card-tags">
								<span class="tag">技術メモ</span>
								<span class="tag">学習記録</span>
								<span class="tag">開発日誌</span>
							</div>
						</div>
						<div class="card-arrow">
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
							</svg>
						</div>
					</a>

					<!-- Diary Card -->
					<a href="/diary" class="nav-card">
						<div class="card-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
								<path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
							</svg>
						</div>
						<div class="card-body">
							<h3 class="card-title">日常の日記</h3>
							<p class="card-description">
								日々の気づき、思考の断片、日常の出来事。技術とは関係なく、ただ言葉を残したい日のために。
							</p>
							<div class="card-tags">
								<span class="tag">日常</span>
								<span class="tag">気づき</span>
								<span class="tag">振り返り</span>
							</div>
						</div>
						<div class="card-arrow">
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
							</svg>
						</div>
					</a>

				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: 100%;
		max-width: 1000px;
		margin: 0 auto;
		padding: 0 1.5em;
	}

	/* ---- Hero ---- */
	.hero {
		position: relative;
		padding: 5em 0 4em;
		overflow: hidden;
	}
	.hero-content {
		position: relative;
		z-index: 1;
		max-width: 640px;
	}
	.hero-eyebrow {
		font-size: 0.8em;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 0.8em;
		font-weight: 600;
	}
	.hero-title {
		font-size: clamp(2.5em, 7vw, 4.5em);
		font-weight: 800;
		line-height: 1.1;
		margin: 0 0 0.5em;
		color: var(--text-primary);
		letter-spacing: -0.03em;
	}
	.hero-title-accent {
		background: linear-gradient(135deg, #2563eb, #7c3aed);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
	.hero-description {
		font-size: 1.1em;
		color: var(--text-secondary);
		line-height: 1.8;
		margin-bottom: 2em;
	}
	.hero-cta {
		display: flex;
		gap: 1em;
		flex-wrap: wrap;
	}
	.btn {
		display: inline-block;
		padding: 0.65em 1.5em;
		border-radius: 8px;
		font-weight: 600;
		font-size: 0.95em;
		text-decoration: none;
		transition: all 0.2s ease;
	}
	.btn-primary {
		background: var(--accent);
		color: #fff;
		box-shadow: 0 0 20px rgba(37, 99, 235, 0.25);
	}
	.btn-primary:hover {
		background: #1d4ed8;
		box-shadow: 0 0 28px rgba(37, 99, 235, 0.35);
		transform: translateY(-1px);
		opacity: 1;
	}
	.btn-secondary {
		background: transparent;
		color: var(--text-secondary);
		border: 1px solid var(--border-color);
	}
	.btn-secondary:hover {
		border-color: var(--accent);
		color: var(--accent);
		background: rgba(37, 99, 235, 0.05);
		opacity: 1;
	}

	/* Decoration rings */
	.hero-decoration {
		position: absolute;
		right: -80px;
		top: 50%;
		transform: translateY(-50%);
		width: 500px;
		height: 500px;
		pointer-events: none;
	}
	.decoration-ring {
		position: absolute;
		border-radius: 50%;
		border: 1px solid rgba(37, 99, 235, 0.1);
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
	}
	.ring-1 { width: 200px; height: 200px; border-color: rgba(37, 99, 235, 0.15); }
	.ring-2 { width: 320px; height: 320px; }
	.ring-3 { width: 440px; height: 440px; border-color: rgba(37, 99, 235, 0.05); }
	.decoration-dots {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--accent);
		box-shadow: 0 0 20px rgba(37, 99, 235, 0.5);
	}

	/* ---- Section ---- */
	.nav-section {
		padding: 2em 0 5em;
	}
	.section-label {
		font-size: 0.75em;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--text-muted);
		margin-bottom: 1.5em;
		font-weight: 600;
	}

	/* ---- Cards ---- */
	.cards-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.25em;
	}
	.nav-card {
		display: flex;
		flex-direction: column;
		padding: 1.75em;
		background: var(--bg-card);
		border: 1px solid var(--border-color);
		border-radius: 16px;
		text-decoration: none;
		color: inherit;
		transition: all 0.25s ease;
		position: relative;
		overflow: hidden;
	}
	.nav-card::before {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(135deg, rgba(37, 99, 235, 0.03) 0%, transparent 60%);
		opacity: 0;
		transition: opacity 0.25s ease;
	}
	.nav-card:hover {
		border-color: var(--border-hover);
		transform: translateY(-3px);
		box-shadow: 0 12px 40px rgba(0, 0, 0, 0.1), 0 0 0 1px rgba(37, 99, 235, 0.1);
		opacity: 1;
	}
	.nav-card:hover::before {
		opacity: 1;
	}
	.card-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 52px;
		height: 52px;
		background: rgba(37, 99, 235, 0.07);
		border: 1px solid rgba(37, 99, 235, 0.15);
		border-radius: 12px;
		color: var(--accent);
		margin-bottom: 1.25em;
		flex-shrink: 0;
	}
	.card-body {
		flex: 1;
	}
	.card-title {
		font-size: 1.15em;
		font-weight: 700;
		color: var(--text-primary);
		margin: 0 0 0.5em;
	}
	.card-description {
		font-size: 0.85em;
		color: var(--text-secondary);
		line-height: 1.7;
		margin: 0 0 1.25em;
	}
	.card-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4em;
	}
	.tag {
		font-size: 0.7em;
		padding: 0.25em 0.65em;
		background: rgba(37, 99, 235, 0.06);
		border: 1px solid rgba(37, 99, 235, 0.12);
		border-radius: 20px;
		color: var(--text-muted);
		letter-spacing: 0.02em;
	}
	.card-arrow {
		display: flex;
		justify-content: flex-end;
		color: var(--text-muted);
		margin-top: 1.25em;
		transition: all 0.2s ease;
	}
	.nav-card:hover .card-arrow {
		color: var(--accent);
		transform: translateX(4px);
	}

	@media (max-width: 900px) {
		.cards-grid {
			grid-template-columns: 1fr;
		}
		.nav-card {
			flex-direction: row;
			align-items: flex-start;
			gap: 1.25em;
		}
		.card-icon {
			margin-bottom: 0;
		}
		.card-arrow {
			margin-top: auto;
			padding-top: 1em;
		}
		.hero-decoration {
			display: none;
		}
	}
	@media (max-width: 600px) {
		.hero {
			padding: 3em 0 2.5em;
		}
		.nav-card {
			flex-direction: column;
		}
		.card-icon {
			margin-bottom: 1em;
		}
	}
</style>
