---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const works = (await getCollection('works')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`成果物置き場 | ${SITE_TITLE}`} description="これまでに作ったWebアプリ・ツール・OSS一覧" />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<p class="page-eyebrow">Portfolio</p>
				<h1 class="page-title">成果物置き場</h1>
				<p class="page-description">これまでに作ったWebアプリ、ツール、OSSプロジェクトを紹介します。</p>
			</div>

			<div class="works-grid">
				{works.map((work) => (
					<article class="work-card">
						<div class="work-card-header">
							<div class="work-icon" aria-hidden="true">
								<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<rect width="20" height="14" x="2" y="3" rx="2"/>
									<line x1="8" x2="16" y1="21" y2="21"/>
									<line x1="12" x2="12" y1="17" y2="21"/>
								</svg>
							</div>
							<time class="work-date"><FormattedDate date={work.data.pubDate} /></time>
						</div>
						<h2 class="work-title">{work.data.title}</h2>
						<p class="work-description">{work.data.description}</p>
						<div class="work-tech">
							{work.data.techStack.map((tech) => (
								<span class="tech-badge">{tech}</span>
							))}
						</div>
						<div class="work-links">
							{work.data.liveUrl && (
								<a href={work.data.liveUrl} target="_blank" rel="noopener noreferrer" class="work-link work-link-primary">
									<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
										<polyline points="15 3 21 3 21 9"/>
										<line x1="10" x2="21" y1="14" y2="3"/>
									</svg>
									Live Demo
								</a>
							)}
							{work.data.githubUrl && (
								<a href={work.data.githubUrl} target="_blank" rel="noopener noreferrer" class="work-link work-link-secondary">
									<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.2c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
										<path d="M9 18c-4.51 2-5-2-7-2"/>
									</svg>
									GitHub
								</a>
							)}
						</div>
					</article>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: 100%;
		max-width: 1000px;
		margin: 0 auto;
		padding: 0 1.5em 5em;
	}
	.page-header {
		padding: 4em 0 3em;
		border-bottom: 1px solid var(--border-color);
		margin-bottom: 3em;
	}
	.page-eyebrow {
		font-size: 0.75em;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 0.5em;
		font-weight: 600;
	}
	.page-title {
		font-size: 2.5em;
		font-weight: 800;
		margin: 0 0 0.4em;
		letter-spacing: -0.03em;
	}
	.page-description {
		color: var(--text-secondary);
		font-size: 1em;
		margin: 0;
	}

	.works-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 1.5em;
	}
	.work-card {
		background: var(--bg-card);
		border: 1px solid var(--border-color);
		border-radius: 16px;
		padding: 1.75em;
		display: flex;
		flex-direction: column;
		transition: all 0.25s ease;
	}
	.work-card:hover {
		border-color: var(--border-hover);
		transform: translateY(-3px);
		box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
	}
	.work-card-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 1em;
	}
	.work-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 42px;
		height: 42px;
		background: rgba(79, 156, 249, 0.1);
		border: 1px solid rgba(79, 156, 249, 0.2);
		border-radius: 10px;
		color: var(--accent);
	}
	.work-date {
		font-size: 0.75em;
		color: var(--text-muted);
	}
	.work-title {
		font-size: 1.15em;
		font-weight: 700;
		margin: 0 0 0.6em;
		color: var(--text-primary);
		line-height: 1.3;
	}
	.work-description {
		font-size: 0.85em;
		color: var(--text-secondary);
		line-height: 1.7;
		margin: 0 0 1.25em;
		flex: 1;
	}
	.work-tech {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4em;
		margin-bottom: 1.25em;
	}
	.tech-badge {
		font-size: 0.7em;
		padding: 0.25em 0.65em;
		background: rgba(79, 156, 249, 0.08);
		border: 1px solid rgba(79, 156, 249, 0.18);
		border-radius: 20px;
		color: var(--accent);
		font-weight: 500;
	}
	.work-links {
		display: flex;
		gap: 0.75em;
		flex-wrap: wrap;
	}
	.work-link {
		display: inline-flex;
		align-items: center;
		gap: 0.4em;
		padding: 0.45em 1em;
		border-radius: 8px;
		font-size: 0.8em;
		font-weight: 600;
		text-decoration: none;
		transition: all 0.2s ease;
	}
	.work-link-primary {
		background: var(--accent);
		color: #fff;
	}
	.work-link-primary:hover {
		background: #3b88e8;
		opacity: 1;
	}
	.work-link-secondary {
		background: transparent;
		color: var(--text-secondary);
		border: 1px solid var(--border-color);
	}
	.work-link-secondary:hover {
		border-color: var(--accent);
		color: var(--accent);
		background: rgba(79, 156, 249, 0.06);
		opacity: 1;
	}

	@media (max-width: 720px) {
		.works-grid {
			grid-template-columns: 1fr;
		}
		.page-title {
			font-size: 2em;
		}
	}
</style>
