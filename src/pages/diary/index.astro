---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const entries = (await getCollection('diary')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`日常の日記 | ${SITE_TITLE}`} description="日々の気づき、思考の断片、日常の出来事を記録する場所。" />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<p class="page-eyebrow">Daily Life</p>
				<h1 class="page-title">日常の日記</h1>
				<p class="page-description">日々の気づき、思考の断片、日常の出来事。技術とは関係なく、ただ言葉を残したい日のために。</p>
			</div>

			<ul class="entries-list">
				{entries.map((entry) => (
					<li>
						<a href={`/diary/${entry.id}/`} class="entry-card">
							<div class="entry-meta">
								<time class="entry-date"><FormattedDate date={entry.data.pubDate} /></time>
								{entry.data.tags && entry.data.tags.length > 0 && (
									<div class="entry-tags">
										{entry.data.tags.map((tag) => (
											<span class="entry-tag">{tag}</span>
										))}
									</div>
								)}
							</div>
							<h2 class="entry-title">{entry.data.title}</h2>
							<p class="entry-description">{entry.data.description}</p>
							<span class="entry-read-more">
								続きを読む
								<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
								</svg>
							</span>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: 100%;
		max-width: 760px;
		margin: 0 auto;
		padding: 0 1.5em 5em;
	}
	.page-header {
		padding: 4em 0 3em;
		border-bottom: 1px solid var(--border-color);
		margin-bottom: 3em;
	}
	.page-eyebrow {
		font-size: 0.75em;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 0.5em;
		font-weight: 600;
	}
	.page-title {
		font-size: 2.5em;
		font-weight: 800;
		margin: 0 0 0.4em;
		letter-spacing: -0.03em;
	}
	.page-description {
		color: var(--text-secondary);
		font-size: 1em;
		margin: 0;
	}

	.entries-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1em;
	}
	.entry-card {
		display: block;
		padding: 1.75em;
		background: var(--bg-card);
		border: 1px solid var(--border-color);
		border-radius: 16px;
		text-decoration: none;
		color: inherit;
		transition: all 0.25s ease;
	}
	.entry-card:hover {
		border-color: var(--border-hover);
		transform: translateY(-2px);
		box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
		opacity: 1;
	}
	.entry-meta {
		display: flex;
		align-items: center;
		gap: 0.75em;
		margin-bottom: 0.75em;
		flex-wrap: wrap;
	}
	.entry-date {
		font-size: 0.78em;
		color: var(--text-muted);
	}
	.entry-tags {
		display: flex;
		gap: 0.4em;
	}
	.entry-tag {
		font-size: 0.68em;
		padding: 0.2em 0.6em;
		background: rgba(37, 99, 235, 0.06);
		border: 1px solid rgba(37, 99, 235, 0.12);
		border-radius: 20px;
		color: var(--text-muted);
	}
	.entry-title {
		font-size: 1.2em;
		font-weight: 700;
		color: var(--text-primary);
		margin: 0 0 0.5em;
		line-height: 1.3;
	}
	.entry-description {
		font-size: 0.88em;
		color: var(--text-secondary);
		line-height: 1.7;
		margin: 0 0 1em;
	}
	.entry-read-more {
		display: inline-flex;
		align-items: center;
		gap: 0.3em;
		font-size: 0.8em;
		color: var(--accent);
		font-weight: 600;
		transition: gap 0.2s ease;
	}
	.entry-card:hover .entry-read-more {
		gap: 0.5em;
	}

	@media (max-width: 720px) {
		.page-title {
			font-size: 2em;
		}
	}
</style>
